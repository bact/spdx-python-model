#! /bin/sh
#
# SPDX-License-Identifier: Apache-2.0

set -e

# SPDX versions to generate
SPDX_VERSIONS="3.0.1"

TOPLEVEL_INIT="__init__.py"
BINDINGS_DIR="bindings"
BINDINGS_INIT="bindings/__init__.py"

# Top-level __init__.py with explicit re-exports for each SPDX version,
# so mypy --strict (--no-implicit-reexport) is satisfied.
echo "# SPDX-License-Identifier: Apache-2.0" > "$TOPLEVEL_INIT"
echo "#" >> "$TOPLEVEL_INIT"
echo "# Generated by generate-bindings at build time. DO NOT EDIT." >> "$TOPLEVEL_INIT"
echo '"""SPDX model in Python."""' >> "$TOPLEVEL_INIT"
echo "" >> "$TOPLEVEL_INIT"

# bindings/__init__.py with imports for each SPDX version.
mkdir -p "$BINDINGS_DIR"

echo "# SPDX-License-Identifier: Apache-2.0" > "$BINDINGS_INIT"
echo "#" >> "$BINDINGS_INIT"
echo "# Generated by generate-bindings at build time. DO NOT EDIT." >> "$BINDINGS_INIT"
echo '"""SPDX model in Python — all supported SPDX versions."""' >> "$BINDINGS_INIT"
echo "" >> "$BINDINGS_INIT"

# Bindings for each SPDX version and add imports to __init__.py files.
for v in $SPDX_VERSIONS; do
    MODNAME="v$(echo "$v" | sed 's/[^a-zA-Z0-9_]/_/g')"

    if [ -n "${SHACL2CODE_SPDX_DIR}" ] && [ -d "${SHACL2CODE_SPDX_DIR}/$v" ]
    then
        shacl2code generate --input "file://${SHACL2CODE_SPDX_DIR}/$v/spdx-model.ttl" \
            --input "file://${SHACL2CODE_SPDX_DIR}/$v/spdx-json-serialize-annotations.ttl" \
            --context-url "file://${SHACL2CODE_SPDX_DIR}/$v/spdx-context.jsonld" https://spdx.org/rdf/$v/spdx-context.jsonld  \
            --license Apache-2.0 \
            python \
            --output "$BINDINGS_DIR/$MODNAME"
    else
        shacl2code generate --input https://spdx.org/rdf/$v/spdx-model.ttl \
            --input https://spdx.org/rdf/$v/spdx-json-serialize-annotations.ttl \
            --context https://spdx.org/rdf/$v/spdx-context.jsonld \
            --license Apache-2.0 \
            python \
            --output "$BINDINGS_DIR/$MODNAME"
    fi

    echo "from . import $MODNAME" >> "$BINDINGS_INIT"
    echo "from .bindings import $MODNAME" >> "$TOPLEVEL_INIT"
done


# Top-level __init__.py: __all__
# uppercase names first (VERSION), then version modules (v3...)
echo "from .version import VERSION" >> "$TOPLEVEL_INIT"
echo "" >> "$TOPLEVEL_INIT"
echo "__all__ = [" >> "$TOPLEVEL_INIT"
echo '    "VERSION",' >> "$TOPLEVEL_INIT"

# bindings/__init__.py: __all__
echo "" >> "$BINDINGS_INIT"
echo "__all__ = [" >> "$BINDINGS_INIT"

for v in $SPDX_VERSIONS; do
    MODNAME="v$(echo "$v" | sed 's/[^a-zA-Z0-9_]/_/g')"
    echo "    \"$MODNAME\"," >> "$TOPLEVEL_INIT"
    echo "    \"$MODNAME\"," >> "$BINDINGS_INIT"
done

echo "]" >> "$TOPLEVEL_INIT"
echo "]" >> "$BINDINGS_INIT"
